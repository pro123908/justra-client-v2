          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [109, 105, 108, 101, 115, 116, 111, 110, 101]
              },
              {
                "kind": "account",
                "path": "consumer"
              },
              {
                "kind": "account",
                "path": "milestone_pda.provider",
                "account": "Milestone"
              },
              {
                "kind": "account",
                "path": "milestone_pda.milestone_id",
                "account": "Milestone"
              }
            ]
          }
        },
        {
          "name": "system_program",
          "address": "11111111111111111111111111111111"
        }
      ],
      "args": []
    },
