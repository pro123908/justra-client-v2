      "discriminator": [216, 92, 128, 146, 202, 85, 135, 73],
      "accounts": [
        {
          "name": "initiator",
          "docs": ["The party raising the dispute — must be either provider or consumer"],
          "signer": true
        },
        {
          "name": "provider",
          "relations": ["milestone_pda"]
        },
        {
          "name": "consumer",
          "relations": ["milestone_pda"]
        },
        {
          "name": "milestone_pda",
          "docs": ["Milestone PDA — funds remain locked; only status changes"],
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [109, 105, 108, 101, 115, 116, 111, 110, 101]
              },
              {
                "kind": "account",
                "path": "consumer"
              },
              {
                "kind": "account",
                "path": "provider"
              },
              {
                "kind": "account",
                "path": "milestone_pda.milestone_id",
                "account": "Milestone"
              }
            ]
          }
        }
      ],
      "args": []
    },
    {
