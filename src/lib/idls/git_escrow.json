          "docs": ["Hardcoded platform wallet receives the fee"],
          "writable": true,
          "address": "AKnL4NNf3DGWZJS6cPknBuEGnVsV4A4m5tgebLHaRSZ9"
        },
        {
          "name": "milestone_pda",
          "docs": [
            "Milestone PDA — seeds enforce that this PDA belongs to this consumer/provider pair"
