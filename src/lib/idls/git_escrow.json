          "address": "9hSR6S7WPtxmTojgo6GG3k4yDPecgJY292j7xrsUGWBu"
        },
        {
          "name": "consumer",
          "docs": ["Consumer receives their share of the funds (if any)"],
          "writable": true,
          "relations": ["milestone_pda"]
        },
        {
          "name": "provider",
          "docs": ["Provider receives their share of the funds (if any)"],
          "writable": true,
          "relations": ["milestone_pda"]
        },
        {
          "name": "platform_wallet",
          "docs": ["Platform wallet receives its fee on the provider's portion"],
          "writable": true,
          "address": "AKnL4NNf3DGWZJS6cPknBuEGnVsV4A4m5tgebLHaRSZ9"
        },
        {
          "name": "milestone_pda",
          "docs": ["Milestone PDA — must currently be in Disputed status"],
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [109, 105, 108, 101, 115, 116, 111, 110, 101]
              },
              {
                "kind": "account",
                "path": "consumer"
              },
              {
                "kind": "account",
                "path": "provider"
              },
              {
                "kind": "account",
