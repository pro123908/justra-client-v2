        {
          "name": "consumer",
          "docs": ["Consumer receives the full refund and must authorise this instruction"],
          "writable": true,
          "signer": true,
          "relations": ["milestone_pda"]
        },
        {
          "name": "milestone_pda",
          "docs": [
            "Milestone PDA — seeds enforce ownership; consumer is both signer and recipient"
