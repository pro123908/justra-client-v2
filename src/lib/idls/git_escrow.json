        {
          "name": "milestone_pda",
          "docs": ["Milestone PDA — holds escrow state and the locked SOL"],
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [109, 105, 108, 101, 115, 116, 111, 110, 101]
              },
              {
                "kind": "account",
                "path": "consumer"
              },
              {
                "kind": "account",
                "path": "provider"
              },
              {
                "kind": "arg",
                "path": "milestone_id"
              }
