{
  "buildCommand": "bun run build && mkdir -p public && cp -R dist/client/assets public/assets",
  "installCommand": "bun install",
  "functions": {
    "api/[[path]].ts": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/api/:path*"
    }
  ]
}
